<?xml version="1.0"?>
<robot name="amazinghand" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    hand.urdf.xacro — full hand assembly.

    Arguments:
      hand_name   : "right_hand" | "left_hand"
      serial_port : e.g. "/dev/ttyUSB0"
      use_sim     : "true" uses gz_ros2_control, "false" uses real hardware plugin

    Adding or removing fingers: edit the finger block list below.
    The ros2_control <hardware> section is built automatically from the same
    finger parameter set — no separate config needs updating.
  -->

  <xacro:arg name="hand_name"   default="right_hand"/>
  <xacro:arg name="serial_port" default="/dev/ttyUSB0"/>
  <xacro:arg name="use_sim"     default="false"/>

  <xacro:include filename="$(find amazinghand_description)/urdf/finger.xacro"/>

  <!-- ====================================================================== -->
  <!-- Palm link                                                               -->
  <!-- ====================================================================== -->
  <link name="$(arg hand_name)_palm_link">
    <visual>
      <geometry><box size="0.090 0.080 0.020"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.090 0.080 0.020"/></geometry>
    </collision>
    <inertial>
      <mass value="0.200"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ====================================================================== -->
  <!-- Fingers — edit this block to add/remove fingers.                       -->
  <!-- id, leader_id, follower_id must match hand.yaml                        -->
  <!-- ====================================================================== -->

  <xacro:amazinghand_finger
    hand_name="$(arg hand_name)"
    finger_name="index"
    leader_id="1"  follower_id="2"
    chirality="right"
    parent="$(arg hand_name)_palm_link"
    origin_xyz="0.045  0.020 0.010"
    origin_rpy="0 0 0"/>

  <xacro:amazinghand_finger
    hand_name="$(arg hand_name)"
    finger_name="middle"
    leader_id="3"  follower_id="4"
    chirality="right"
    parent="$(arg hand_name)_palm_link"
    origin_xyz="0.045  0.000 0.010"
    origin_rpy="0 0 0"/>

  <xacro:amazinghand_finger
    hand_name="$(arg hand_name)"
    finger_name="ring"
    leader_id="5"  follower_id="6"
    chirality="right"
    parent="$(arg hand_name)_palm_link"
    origin_xyz="0.045 -0.020 0.010"
    origin_rpy="0 0 0"/>

  <xacro:amazinghand_finger
    hand_name="$(arg hand_name)"
    finger_name="thumb"
    leader_id="7"  follower_id="8"
    chirality="right"
    parent="$(arg hand_name)_palm_link"
    origin_xyz="0.015 -0.040 0.010"
    origin_rpy="0 0 -0.7854"/>

  <!-- ====================================================================== -->
  <!-- ros2_control hardware block                                             -->
  <!-- Finger parameters are passed as <param> tags so the hardware interface -->
  <!-- can reconstruct FingerConfig objects without a separate YAML read.      -->
  <!-- ====================================================================== -->
  <ros2_control name="$(arg hand_name)" type="system">

    <xacro:if value="$(arg use_sim)">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
    </xacro:if>
    <xacro:unless value="$(arg use_sim)">
      <hardware>
        <plugin>amazinghand_hardware/AmazingHandHardwareInterface</plugin>
        <param name="hand_name">$(arg hand_name)</param>
        <param name="serial_port">$(arg serial_port)</param>
        <param name="baud_rate">1000000</param>
        <param name="servo_min_pos">200</param>
        <param name="servo_max_pos">824</param>
        <!-- Finger 0: index -->
        <param name="finger.0.name">index</param>
        <param name="finger.0.chirality">right</param>
        <param name="finger.0.leader_id">1</param>
        <param name="finger.0.follower_id">2</param>
        <!-- Finger 1: middle -->
        <param name="finger.1.name">middle</param>
        <param name="finger.1.chirality">right</param>
        <param name="finger.1.leader_id">3</param>
        <param name="finger.1.follower_id">4</param>
        <!-- Finger 2: ring -->
        <param name="finger.2.name">ring</param>
        <param name="finger.2.chirality">right</param>
        <param name="finger.2.leader_id">5</param>
        <param name="finger.2.follower_id">6</param>
        <!-- Finger 3: thumb -->
        <param name="finger.3.name">thumb</param>
        <param name="finger.3.chirality">right</param>
        <param name="finger.3.leader_id">7</param>
        <param name="finger.3.follower_id">8</param>
      </hardware>
    </xacro:unless>

    <!-- Semantic joints — one flexion + one abduction per finger -->
    <!-- Index -->
    <joint name="$(arg hand_name)_index_flexion">
      <command_interface name="position">
        <param name="min">-1.5708</param><param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg hand_name)_index_abduction">
      <command_interface name="position">
        <param name="min">-0.5236</param><param name="max">0.5236</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Middle -->
    <joint name="$(arg hand_name)_middle_flexion">
      <command_interface name="position">
        <param name="min">-1.5708</param><param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg hand_name)_middle_abduction">
      <command_interface name="position">
        <param name="min">-0.5236</param><param name="max">0.5236</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Ring -->
    <joint name="$(arg hand_name)_ring_flexion">
      <command_interface name="position">
        <param name="min">-1.5708</param><param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg hand_name)_ring_abduction">
      <command_interface name="position">
        <param name="min">-0.5236</param><param name="max">0.5236</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Thumb -->
    <joint name="$(arg hand_name)_thumb_flexion">
      <command_interface name="position">
        <param name="min">-1.5708</param><param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg hand_name)_thumb_abduction">
      <command_interface name="position">
        <param name="min">-0.5236</param><param name="max">0.5236</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

  </ros2_control>

</robot>
